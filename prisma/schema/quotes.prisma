// Model Quotes

model Quotes {
  id                  String   @id @default(uuid())
  provider_id         String
  name                String
  email               String
  identification      String
  identification_type String
  user_id             String?
  type                String   @default("CLIENT") // si es CLIENT es una cotización creada por cliente y PROVIDER fue creada por un proveedor
  description         String   @db.Text
  status              String   @default("PENDING")
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  provider             Providers            @relation(fields: [provider_id], references: [id])
  quote_items          QuoteItems[]
  quote_message        QuoteMessages[]
  quote_public_request QuotePublicRequest[]

  @@index([provider_id])
  @@index([user_id])
  @@index([email])
  @@index([status])
}

// Model QuoteItems

model QuoteItems {
  id          String   @id @default(uuid())
  quote_id    String
  item_id     String?
  name        String
  description String?
  quantity    Int
  price       Decimal  @default(0.00) @db.Decimal(10, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  quote Quotes @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  item  Items? @relation(fields: [item_id], references: [id])

  @@index([quote_id])
}

model QuoteMessages {
  id         String   @id @default(uuid())
  quote_id   String
  user_id    String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  quote Quotes @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  user  Users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model QuotePublicRequest {
  id                String   @id @default(uuid())
  quote_id          String
  public_request_id String
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now())

  quote          Quotes         @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  public_request PublicRequests @relation(fields: [public_request_id], references: [id], onDelete: Cascade)
}
