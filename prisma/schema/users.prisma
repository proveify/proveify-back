// Model Users

model Users {
  id                  String     @id @default(uuid())
  name                String
  email               String     @unique
  password            String
  user_type           String
  identification      String
  identification_type String
  phone               String?
  refreshed_token     String?
  profile_picture_id  String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @default(now()) @updatedAt
  provider            Providers?

  files                 Files[]
  favorites             Favorites[]
  publicRequest         PublicRequests[]
  quoteMessage          QuoteMessages[]
  ProviderQuoteMessages ProviderQuoteMessages[]
}
